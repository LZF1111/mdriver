# ====================  Mdriver Configuration  ====================
# 复制为 .env 并按需修改。

# ---------- LAMMPS 安装包 ----------
# Mdriver 的核心：让 LLM 能"看懂"你的 LAMMPS 安装包并复用 examples / 源码 / 文档。
# 必须指向 LAMMPS 源码根目录（含 src/ 与 examples/ 子目录）。
LAMMPS_ROOT=C:/lammps
# LAMMPS_ROOT=/opt/lammps
# LAMMPS_ROOT=/home/user/lammps-23Jun2022

# LAMMPS 可执行文件（不在 PATH 时给绝对路径）
LAMMPS_BIN=lmp_serial
# LAMMPS_BIN=lmp.exe
# LAMMPS_BIN=/opt/lammps/build/lmp
# LAMMPS_BIN=lmp_mpi


# ---------- LLM Provider（任选其一或多个；按下方优先级回退）----------
# 推荐：OpenAI 兼容接口（DeepSeek / Moonshot / 阿里通义 / SiliconFlow / OpenRouter 等）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-latest

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# GitHub Copilot（实验性）
GITHUB_COPILOT_TOKEN=


# ---------- 联网搜索（可选；按优先级使用）----------
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_API_KEY=
SEARXNG_URL=


# ---------- 网络代理（可选）----------
# HTTPS_PROXY=http://127.0.0.1:7890


# ---------- 服务端口 ----------
PORT=3000
